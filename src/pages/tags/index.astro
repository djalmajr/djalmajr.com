---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags } from "../../utils/tags";
import Tag from "../../components/ui/Tag.astro";
import ContentHeader from "../../components/content/ContentHeader.astro";
import { useTranslations, tplStr } from "../../i18n";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

const tags = await getAllTags();

const maxCount = Math.max(...tags.map(tag => tag.count));
const minCount = Math.min(...tags.map(tag => tag.count));

function getTagSize(count: number): "sm" | "md" | "lg" {
  if (tags.length < 5) return "md";
  const range = maxCount - minCount;
  if (range === 0) return "md";

  const normalized = (count - minCount) / range;
  if (normalized > 0.7) return "lg";
  if (normalized > 0.3) return "md";
  return "sm";
}
---

<BaseLayout title={t.pages.tagsTitle}>
  <div class="content-container">
    <ContentHeader
      title={t.pages.tagsTitle}
      meta={[{ value: tplStr(t.tags.uniqueTopics, { count: tags.length }) }]}
    />

    <div class="container-narrow">
      <div
        class="stagger-fade-in flex flex-wrap items-center justify-start gap-3"
      >
        {
          tags.map(tag => (
            <Tag
              name={tag.name}
              count={tag.count}
              size={getTagSize(tag.count)}
            />
          ))
        }
      </div>

      {
        tags.length === 0 && (
          <p class="text-text-muted mt-20 text-center font-mono italic">
            No tags found in your content yet.
          </p>
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  .flex-wrap > * {
    animation: fade-in 0.4s ease-out forwards;
    opacity: 0;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

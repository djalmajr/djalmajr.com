---
import { getRelativeLocaleUrl } from "astro:i18n";
import BaseDetail from "../../layouts/BaseDetail.astro";
import { getSlugs } from "../../utils/localeContent";
import { PAGES } from "../../config";

const locale = Astro.currentLocale ?? "en";

if (PAGES.projects.isActive === false) {
  return Astro.redirect(getRelativeLocaleUrl(locale, "/404"));
}

export async function getStaticPaths() {
  if (PAGES.projects.isActive === false) return [];
  const slugs = await getSlugs("projects");
  return slugs.map(slug => ({ params: { id: slug }, props: {} }));
}

const { id } = Astro.params;
---

<BaseDetail collection="projects" id={id} />

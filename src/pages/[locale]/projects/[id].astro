---
import type { GetStaticPaths } from "astro";
import { NonDefaultLocales } from "../../../i18n/locales";
import { getSlugs } from "../../../utils/localeContent";
import ProjectDetailPage from "../../projects/[id].astro";

export const getStaticPaths = (async () => {
  const slugs = await getSlugs("projects");
  return NonDefaultLocales.flatMap(locale =>
    slugs.map(slug => ({ params: { locale, id: slug } }))
  );
}) satisfies GetStaticPaths;
---

<ProjectDetailPage />

---
import { getEntry, render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Timeline from "../../components/ui/Timeline.astro";
import { PAGES } from "../../config";
import { useTranslations } from "../../i18n";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

if (PAGES.cv.isActive === false) {
  return Astro.redirect(getRelativeLocaleUrl(locale, "/404"));
}

const cvEntry = (await getEntry("cv", locale)) ?? (await getEntry("cv", "en"));
if (!cvEntry) {
  throw new Error(
    "CV content not found. Please ensure src/content/cv/{locale}.md exists."
  );
}

const { Content } = await render(cvEntry);
const { experience = [], education = [] } = cvEntry.data;
---

<BaseLayout title={t.pages.cvTitle}>
  <header class="page-header">
    <h1 class="page-title">{t.pages.cvTitle}</h1>
    <p class="page-subtitle">{t.pages.cvSubtitle}</p>
  </header>

  <div class="container-narrow">
    {
      experience.length > 0 && (
        <section class="section">
          <h2 class="section-title border-border border-b pb-2">
            {t.pages.experience}
          </h2>
          <Timeline
            items={experience.map(exp => ({
              title: exp.role,
              subtitle: exp.institution,
              period: exp.period,
              description: exp.description,
            }))}
          />
        </section>
      )
    }

    {
      education.length > 0 && (
        <section class="section">
          <h2 class="section-title border-border border-b pb-2">
            {t.pages.education}
          </h2>
          <Timeline
            items={education.map(edu => ({
              title: edu.degree,
              subtitle: edu.institution,
              period: edu.period,
              description: edu.description,
              thesis: edu.thesis,
            }))}
          />
        </section>
      )
    }

    <div class="prose max-w-none">
      <Content />
    </div>
  </div>
</BaseLayout>

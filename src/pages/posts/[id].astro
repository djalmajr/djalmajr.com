---
import { getAbsoluteLocaleUrl, getRelativeLocaleUrl } from "astro:i18n";
import BaseDetail from "../../layouts/BaseDetail.astro";
import ShareButtons from "../../components/ui/ShareButtons.astro";
import {
  getLocalizedEntries,
  getSlugs,
  slugFromId,
} from "../../utils/localeContent";
import { sortPostsByDate } from "../../utils/posts";
import { PAGES } from "../../config";
import { useTranslations } from "../../i18n";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

if (PAGES.blog.isActive === false) {
  return Astro.redirect(getRelativeLocaleUrl(locale, "/404"));
}

export async function getStaticPaths() {
  if (PAGES.blog.isActive === false) return [];
  const slugs = await getSlugs("posts");
  return slugs.map(slug => ({ params: { id: slug }, props: {} }));
}

const { id } = Astro.params;

// Determine prev/next within the current locale's (fallback-filled) post set.
const localized = await getLocalizedEntries("posts", locale);
const sorted = sortPostsByDate(localized as any);
const index = sorted.findIndex(p => slugFromId(p.id) === id);
const current = sorted[index];
const prevPost = index > 0 ? sorted[index - 1] : null;
const nextPost =
  index >= 0 && index < sorted.length - 1 ? sorted[index + 1] : null;

const postUrl = getAbsoluteLocaleUrl(locale, `/posts/${id}`);
const prevHref = prevPost
  ? getRelativeLocaleUrl(locale, `/posts/${slugFromId(prevPost.id)}`)
  : "";
const nextHref = nextPost
  ? getRelativeLocaleUrl(locale, `/posts/${slugFromId(nextPost.id)}`)
  : "";
---

<BaseDetail collection="posts" id={id}>
  <nav
    slot="footer"
    class="post-navigation container-narrow mt-24 flex justify-between gap-8 pt-12"
  >
    {
      prevPost && (
        <a
          href={prevHref}
          class="nav-prev group flex max-w-[45%] flex-col no-underline"
        >
          <span class="nav-label mb-2 text-[0.8rem] font-bold tracking-wider uppercase opacity-75">
            {t.buttons.previousPost}
          </span>
          <span class="nav-title text-foreground group-hover:text-accent text-lg leading-snug font-semibold transition-colors duration-200">
            {prevPost.data.title}
          </span>
        </a>
      )
    }
    <div class="nav-spacer flex-1"></div>
    {
      nextPost && (
        <a
          href={nextHref}
          class="nav-next group flex max-w-[45%] flex-col items-end text-right no-underline"
        >
          <span class="nav-label mb-2 text-[0.8rem] font-bold tracking-wider uppercase opacity-75">
            {t.buttons.nextPost}
          </span>
          <span class="nav-title text-foreground group-hover:text-accent text-lg leading-snug font-semibold transition-colors duration-200">
            {nextPost.data.title}
          </span>
        </a>
      )
    }
  </nav>
  <div slot="share" class="container-narrow">
    <ShareButtons
      title={current?.data.title}
      url={postUrl}
      description={current?.data.description}
    />
  </div>
</BaseDetail>

---
import { render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import BaseLayout from "./BaseLayout.astro";
import BackLink from "../components/ui/BackLink.astro";
import Tag from "../components/ui/Tag.astro";
import Icon from "../components/ui/Icon.astro";
import { getDetailItem } from "../utils/adapters";
import { getLocalizedEntry } from "../utils/localeContent";
import { SITE } from "../config";
import { useTranslations } from "../i18n";

interface Props {
  collection: "projects" | "posts";
  id: string;
}

const { collection, id } = Astro.props;

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

const entry = (await getLocalizedEntry(collection, locale, id)) as any;

if (!entry) return Astro.redirect(getRelativeLocaleUrl(locale, "/404"));

const { Content } = await render(entry);
const detail = getDetailItem(entry, collection);

const backHref = getRelativeLocaleUrl(locale, `/${collection}`);
const backLabel = collection === "posts" ? t.nav.posts : t.nav.projects;

const meta = [];
if (detail.date) meta.push({ value: detail.date, icon: "Calendar" });
if (detail.authors) meta.push({ value: detail.authors, icon: "User" });

const description = entry.data.description || detail.description || SITE.desc;
const ogImage = entry.data.image || SITE.ogImage;
---

<BaseLayout
  title={detail.title}
  description={description}
  ogImage={ogImage}
  ogType="article"
>
  <div class="mb-4 flex items-center justify-between">
    <BackLink href={backHref} label={backLabel} />
    {
      detail.externalUrl && (
        <a
          href={detail.externalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted hover:text-foreground body-xs inline-flex items-center gap-1 transition-colors"
        >
          {t.buttons.viewExternal}
          <Icon name="ExternalLink" size={12} />
        </a>
      )
    }
  </div>

  <article>
    <h1 class="page-title mb-4">{detail.title}</h1>

    {
      meta.length > 0 && (
        <div class="card-meta mb-4">
          {meta.map((m: any) => (
            <span class="flex items-center gap-1">
              <Icon name={m.icon} size={14} />
              <span>{m.value}</span>
            </span>
          ))}
        </div>
      )
    }

    {
      detail.tags && detail.tags.length > 0 && (
        <div class="mb-4 flex flex-wrap gap-2">
          {detail.tags.map((tag: string) => (
            <Tag name={tag} size="sm" />
          ))}
        </div>
      )
    }

    <div class="prose">
      <Content />
    </div>

    <slot name="share" />
    <slot name="footer" />
  </article>
</BaseLayout>

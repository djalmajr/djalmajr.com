---
import Icon from "./Icon.astro";
import { useTranslations, tplStr } from "../../i18n";

interface Props {
  title: string;
  url: string;
  description?: string;
}

const { title, url } = Astro.props;

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

const shareUrls = {
  twitter: `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`,
  email: `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(url)}`,
};
---

<div class="mt-8 flex items-center gap-4">
  <span class="body-sm font-semibold" style="opacity: 0.75;"
    >{t.buttons.sharePost}</span
  >
  <div class="flex gap-2">
    <a
      href={shareUrls.twitter}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={tplStr(t.buttons.shareVia, { platform: "Twitter" })}
      class="icon-btn"
    >
      <Icon name="Twitter" size={24} />
    </a>
    <a
      href={shareUrls.facebook}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={tplStr(t.buttons.shareVia, { platform: "Facebook" })}
      class="icon-btn"
    >
      <Icon name="Facebook" size={24} />
    </a>
    <a
      href={shareUrls.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={tplStr(t.buttons.shareVia, { platform: "LinkedIn" })}
      class="icon-btn"
    >
      <Icon name="LinkedIn" size={24} />
    </a>
    <a
      href={shareUrls.email}
      aria-label={tplStr(t.buttons.shareVia, { platform: "Email" })}
      class="icon-btn"
    >
      <Icon name="Mail" size={24} />
    </a>
  </div>
</div>

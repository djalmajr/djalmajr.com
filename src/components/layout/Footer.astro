---
import { getRelativeLocaleUrl } from "astro:i18n";
import { SITE, THEME_CONFIG } from "../../config";
import { useTranslations } from "../../i18n";
import Icon from "../ui/Icon.astro";

const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);
const currentYear = new Date().getFullYear();
const showToggle = THEME_CONFIG.lightAndDark;
const rssHref = getRelativeLocaleUrl(locale, "/rss.xml");
---

<footer class="footer">
  <div class="flex items-center gap-4">
    <span class="body-xs">&copy; {currentYear} {SITE.author}.</span>
  </div>
  <div class="flex items-center gap-4">
    <a
      href="https://djalmajr.dev"
      title={t.footer.devSite}
      target="_blank"
      rel="noopener noreferrer"
      class="body-xs link">djalmajr.dev</a
    >
    <a
      href={rssHref}
      aria-label={t.buttons.rss}
      title={t.buttons.rss}
      target="_blank"
      rel="noreferrer"
      class="btn-icon"
    >
      <Icon name="RSS" size={16} />
    </a>
    {
      showToggle && (
        <button
          id="theme-toggle"
          aria-label={t.buttons.themeToggle}
          class="btn-icon"
        >
          <Icon name="Sun" size={16} class="hidden dark:block" />
          <Icon name="Moon" size={16} class="block dark:hidden" />
        </button>
      )
    }
  </div>
</footer>
